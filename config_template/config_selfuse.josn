{
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "cache_id": "my_profile2",
      "store_fakeip": true
    },
    "clash_api": {
      "external_ui": "ui",
      "external_controller": "0.0.0.0:9090",
      "external_ui_download_detour": "direct",
      "default_mode": "rule",
      "external_ui_download_url": "https://mirror.ghproxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip"
    }
  },
  "log": {
    "disabled": true,
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    },
    "servers": [
      {
        "tag": "google",
        "address": "https://1.1.1.1/dns-query",
        "detour": "Proxy"
      },
      {
        "tag": "local",
        "address": "https://223.5.5.5/dns-query",
        "detour": "direct"
      },
      {
        "tag": "fakeip",
        "address": "fakeip"
      },
      {
        "tag": "block",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "local",
        "disable_cache": true
      },
      {
        "domain_suffix": [
          "edu.cn",
          "gov.cn",
          "mil.cn",
          "ac.cn",
          "com.cn",
          "net.cn",
          "org.cn",
          "中国",
          "中國",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiq228c",
          "xn--fiq228c"
        ],
        "server": "local"
      },
      {
        "rule_set": "geosite-cn",
        "server": "local"
      },
      {
        "domain": [
          "ghproxy.com",
          "cdn.jsdelivr.net",
          "testingcf.jsdelivr.net"
        ],
        "server": "fakeip"
      },
      {
        "rule_set": "geoip-cn",
        "server": "local"
      },
      {
        "rule_set": "geosite-icloud@cn",
        "server": "local"
      },
      {
        "rule_set": "geosite-apple@cn",
        "server": "local"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "server": "google"
      },   
      {
        "clash_mode": "direct",
        "server": "local"
      },
      {
        "clash_mode": "global",
        "server": "fakeip"
      },
      {
        "rule_set": "geosite-category-ads-all",
        "server": "block"
      },
      {
        "inbound": "tun",
        "query_type": [
          "A",
          "AAAA"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip"
      }
    ],
    "final": "google",
    "independent_cache": true,
    "strategy": "prefer_ipv4",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15"
    }
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 8888,
      "sniff": true
    },
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "::",
      "listen_port": 9887,
      "sniff": true
    }{
      "tag": "loop-in",
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7891,
      "sniff": true,
      "domain_strategy": "prefer_ipv4"
    },
    {
      "type": "tun",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fdfe:dcba:9876::0/126",
      "stack": "system",
      "sniff": true,
      "auto_route": true,
      "gso": false,
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "127.0.0.1",
          "server_port": 8888
        }
      }
    }
  ],
