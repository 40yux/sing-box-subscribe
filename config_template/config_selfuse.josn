          "xn--fiqs8s",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiq228c",
          "xn--fiq228c"
        ],
        "outbound": "direct"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 853
          },
          {
            "network": "udp",
            "port": 443
          },
          {
            "protocol": "stun"
          }
        ],
        "outbound": "block"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "Proxy"
      },
      {
        "rule_set": "bm7-Netflix",
        "outbound": "Netflix"
      },
      {
        "rule_set": "bm7-GlobalMedia",
        "outbound": "GlobalMedia"
      },
      {
