{
    "log": {
        "disabled": false,
        "level": "error",
        "timestamp": true
    },
    "dns": {
        "servers": [
            {
                "tag": "dns_proxy",
                "address": "tcp://1.1.1.1",
                "strategy": "prefer_ipv4",
                "detour": "proxy"
            },
            {
                "tag": "dns_direct",
                "address": "https://223.6.6.6/dns-query",
                "strategy": "prefer_ipv4",
                "detour": "direct"
            },
            {
                "tag": "dns_block",
                "address": "rcode://success"
            },
            {   "tag": "dns_fakeip",
                "address": "fakeip"
            }
        ],
        "rules": [
            {
                "outbound": "any",
                "server": "dns_direct"
            },
            {   "clash_mode": "Direct",
                "server": "dns_direct"
            },
            {   "clash_mode": "Global",
                "server": "dns_proxy"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-cn"
                    },
                    {
                        "rule_set": "geosite-cn"
                    }
                ],
                "server": "dns_direct",
                "client_subnet": "127.0.0.1/24"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    },
                    {
                        "rule_set": "geoip-cn"
                    }
                ],
                "server": "dns_direct",
                "client_subnet": "127.0.0.1/24"
            },
            {
                "rule_set": "geosite-category-ads-all",
                "server": "dns_block"
            },
            {
                "query_type": ["A", "AAAA"],      
                "server": "dns_fakeip",
                "rewrite_ttl": 1
            }
        ],
        "final": "dns_proxy",
        "strategy": "prefer_ipv4",
        "independent_cache": false,
        "reverse_mapping": false,
        "client_subnet": "114.114.114.114/24",
        "fakeip": {
            "enabled": true,
            "inet4_range": "198.18.0.0/15",
            "inet6_range": "fc00::/18"
        }
    },
    "route": {
        "rules": [
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "protocol": "dns"
                    },
                    {
                        "port": 53
                    }
                ],
                "outbound": "dns-out"
            },
            {
                "ip_is_private": true,
                "outbound": "direct"
            },
            {
                "clash_mode": "Direct",
                "outbound": "direct"
            },
            {
                "clash_mode": "Global",
                "outbound": "proxy"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "port": 853
                    },
                    {
                        "network": "udp",
                        "port": 443
                    },
                    {
                        "protocol": "stun"
                    }
                ],
                "outbound": "block"
            },
            {
                "rule_set": ["geoip-google", "geosite-google", "geosite-github", "geoip-telegram", "geosite-bahamut"],
                "outbound": "proxy"
            },
            {
                "rule_set": ["geoip-cn", "geosite-cn", "geosite-geolocation-cn", "geoip-private"],
                "outbound": "direct"
            },
            {
                "rule_set": "geosite-category-ads-all",
                "outbound": "block"
            }
        ],
        "final": "proxy",
        "auto_detect_interface": true,
        "rule_set": [
            {
                "tag": "geoip-private",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-private.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geoip-google",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-google.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-google",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-google.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geoip-telegram",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-telegram.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-github",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-github.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-bahamut",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-bahamut.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-geolocation-!cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-geolocation-!cn.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-geolocation-cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-geolocation-cn.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-cn.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geoip-cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geoip/geoip-cn.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-category-ads-all",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/lyc8503/sing-box-rules/rule-set-geosite/geosite-category-ads-all.srs",
                "download_detour": "auto",
                "update_interval": "1d"
            }
        ]
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "inet4_address": "172.16.0.1/30",
            "inet6_address": "fdfe:dcba:9876::1/126",
            "mtu": 1492,
            "auto_route": true,
            "strict_route": true,
            "inet4_route_address": ["0.0.0.0/1", "128.0.0.0/1"],
            "inet6_route_address": ["::/1", "8000::/1"],
            "inet4_route_exclude_address": ["192.168.0.0/16"],
            "inet6_route_exclude_address": ["fc00::/7"],
            "stack": "mixed",
            "exclude_package": [
                "com.android.captiveportallogin",
                "com.dianchou.dcw",
                "com.jaemobird.mutongji",
                "com.MobileTicket",
                "com.tencent.mm",
                "com.tencent.mobileqq",
                "com.miui.cloudservice",
                "com.miui.weather2",
                "com.android.browser",
                "com.iflytek.inputmethod"
            ],
            "platform": {
                "http_proxy": {
                    "enabled": true,
                    "server": "127.0.0.1",
                    "server_port": 7890
                }
            },
            "sniff": true,
            "sniff_override_destination": true
        },
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "listen_port": 7890,
            "users": [],
            "sniff": true,
            "sniff_override_destination": true
        }
    ],
    "outbounds": [
        {
            "tag": "proxy",
            "type": "selector",
            "outbounds": ["auto", "direct", "{all}"],
            "default": "auto",
            "interrupt_exist_connections": true
        },
        {
            "tag": "auto",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action": "exclude", "keywords": ["网站|地址|剩余|过期|时间|有效"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "1m",
            "tolerance": 50,
            "idle_timeout": "30m",
            "interrupt_exist_connections": true
        },
        {
             "tag": "AdBlock",
             "type": "selector",
             "outbounds": ["block", "direct"]
        },
        {
            "tag": "Others",
            "type": "selector",
            "outbounds": ["{all}", "proxy"],
            "filter": [{"action": "exclude", "keywords": ["🇭🇰|HK|hk|香港|香|🇹🇼|TW|tw|台湾|台|🇸🇬|SG|sg|新加坡|狮|🇯🇵|JP|jp|日本|日|🇺🇸|US|us|美国|美|🇰🇷|KR|kr|韩国"]}]
        },
        {
            "type": "direct",
            "tag": "direct"
        },
        {
            "type": "block",
            "tag": "block"
        },
        {
            "type": "dns",
            "tag": "dns-out"
        }
    ],
    "experimental": {
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": false,
            "store_rdrc": true
        },
        "clash_api": {
            "external_controller": "127.0.0.1:9090",
            "external_ui": "ui",
            "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",
            "external_ui_download_detour": "direct",
            "secret": "",
            "default_mode": "Rule"
        }
    }
}
