                "server": "dns_direct"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    },
                    {
                        "match_response": true,
                        "rule_set": "geoip-cn"
                    }
                ],
                "action": "route",
                "server": "dns_proxy",
                "client_subnet": "114.114.114.114/24"
            },
            {
                "query_type": [
                    "A",
                    "AAAA"
