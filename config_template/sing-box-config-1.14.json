                "action": "route",
                "server": "dns_fakeip",
                "rewrite_ttl": 60
            }
        ],
        "final": "dns_proxy",
        "strategy": "prefer_ipv4",
        "optimistic": {
            "enabled": true,
            "timeout": "1h"
