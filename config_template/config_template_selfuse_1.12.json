{
    "log": {
        "disabled": false,
        "level": "error",
        "timestamp": true
    },
    "ntp": {
        "enabled": false,
        "server": "ntp.aliyun.com",
        "server_port": 123,
        "interval": "24h"
    },
    "dns": {
        "servers": [
            {
                "tag": "dns_proxy",
                "type": "https",
                "server": "dns.google",
                "domain_resolver": "hosts",
                "detour": "proxy"
            },
            {
                "tag": "dns_direct",
                "type": "https",
                "server": "dns.alidns.com",
                "domain_resolver": "hosts"
            },
            {
                "tag":"local",
                "type":"local"
            },
            {
                "tag": "hosts",
                "type": "hosts",
                "predefined": {
                    "dns.alidns.com": ["223.5.5.5", "223.6.6.6", "2400:3200::1", "2400:3200:baba::1"],
                    "doh.pub": ["1.12.12.21", "120.53.53.53", "2402:4e00::"],
                    "dns.google": ["8.8.8.8", "8.8.4.4", "2001:4860:4860::8888", "2001:4860:4860::8844"],
                    "cloudflare-dns.com": ["104.16.248.249", "104.16.249.249", "2606:4700:4700::1111", "2606:4700:4700::1001"],
                    "dns.quad9.net": ["9.9.9.9", "9.9.9.11", "2620:fe::fe", "2620:fe::11"]
                }
            },
            {
                "type": "fakeip",
                "tag": "dns_fakeip",
                "inet4_range": "198.18.0.0/15",
                "inet6_range": "fc00::/18"
            }
        ],
        "rules": [            
            {   
                "clash_mode": "Direct",
                "server": "dns_direct"
            },           
            {   "clash_mode": "Global",
                "server": "dns_proxy"
            },
            { 
                "ip_accept_any": true,
                "server": "hosts"
            },
            {
                "query_type":"PTR",
                "server":"local"
            },
            {
                "query_type":["SVCB","QUIC"],
                "action":"reject"
            },
            {
                "rule_set": "geosite-geolocation-cn",
                "server": "dns_direct"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    },
                    {
                        "rule_set": "geoip-cn"
                    }
                ],
                "server": "dns_proxy",
                "client_subnet": "114.114.114.114/24"
            },
            {
                "query_type": ["A", "AAAA"],
                "server": "dns_fakeip"
            }
        ],
        "final": "dns_proxy",
        "strategy": "prefer_ipv4"
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "interface_name": "tun0",
            "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"],
            "mtu": 9000,
            "auto_route": true,
            "auto_redirect": false,
            "loopback_address": ["10.7.0.1"],
            "strict_route": true,
            "route_exclude_address": ["192.168.0.0/16", "fc00::/7"],
            "stack": "system",
            "exclude_package": [
                "com.android.captiveportallogin",
                "cn.gov.tax.its",
                "com.eg.android.AlipayGphone",
                "com.tencent.mm"
            ],
            "platform": {
                "http_proxy": {
                    "enabled": true,
                    "server": "127.0.0.1",
                    "server_port": 7890
                }
            }
        },
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "listen_port": 7890
        }
    ],
    "outbounds": [
        {
            "tag": "proxy",
            "type": "selector",
            "outbounds": ["auto", "direct", "{all}"],
            "default": "auto"
        },
        {
            "tag": "auto",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action": "exclude", "keywords": ["网站|地址|剩余|过期|到期|时间|有效|故障|重置|过滤"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "Others",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action": "exclude", "keywords": ["🇭🇰|HK|hk|香港|香|🇹🇼|TW|tw|台湾|台|🇸🇬|SG|sg|新加坡|狮|🇯🇵|JP|jp|日本|日|🇺🇸|US|us|美国|美网|站|地址|剩余|过期|到期|时间|有效|故障|重置|过滤"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "subscription",
            "type": "selector",
            "outbounds": ["{all}"],
            "filter": [{"action": "include", "keywords": ["网站|地址|剩余|过期|到期|时间|有效|故障|重置|过滤"]}]
        },
        {
            "tag":"direct",
            "type":"direct",
            "domain_resolver":"local"
        },
        {
            "tag": "Youtube",
            "type": "selector",
            "outbounds": ["Japan","America", "HongKong", "TaiWan", "Singapore",  "Others"]
        },
        {
            "tag": "Telegram",
            "type": "selector",
            "outbounds": ["HongKong", "TaiWan", "Singapore", "Japan", "America", "Others"]
        },
        {
            "tag": "Twitter/X",
            "type": "selector",
            "outbounds": ["HongKong", "TaiWan", "Singapore", "Japan", "America", "Others"]
        },
        {
            "tag": "Google",
            "type": "selector",
            "outbounds": ["America", "HongKong", "TaiWan", "Singapore", "Japan", "Others"]
        },
        {
            "tag": "Github",
            "type": "selector",
            "outbounds": ["HongKong", "TaiWan", "Singapore", "Japan", "America", "Others"]
        },
        {
            "tag": "Bahamut",
            "type": "selector",
            "outbounds": ["TaiWan", "HongKong", "Singapore", "America", "Japan", "Others"]
        },
        {
            "tag": "America",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action":"include","keywords":["🇺🇸|US|us|美国|美|United States"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "Japan",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action":"include","keywords":["🇯🇵|JP|jp|日本|日|Japan"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "HongKong",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action":"include","keywords":["🇭🇰|HK|hk|香港|港|HongKong"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "TaiWan",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action":"include","keywords":["🇹🇼|TW|tw|台湾|臺灣|台|Taiwan"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "Singapore",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action":"include","keywords":["🇸🇬|SG|sg|新加坡|狮|Singapore"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        },
        {
            "tag": "proxy-no-jp",
            "type": "urltest",
            "outbounds": ["{all}"],
            "filter": [{"action": "exclude", "keywords": ["网站|地址|剩余|过期|到期|时间|有效|故障|重置|过滤|🇯🇵|JP|jp|日本|日"]}],
            "url": "https://www.gstatic.com/generate_204",
            "interval": "3m",
            "tolerance": 60,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false
        }
    ],
    "route": {
        "rules": [
            {
                "action": "sniff"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "protocol": "dns"
                    },
                    {
                        "port": 53
                    }
                ],
                "action": "hijack-dns"
            },            
            {
                "rule_set": "geosite-category-ads-all",
                "action": "reject",
                "method": "default",
                "no_drop": false
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "port": 853
                    },
                    {
                        "network": "udp",
                        "port": 443
                    },
                    {
                        "protocol": "stun"
                    }
                ],
                "action": "reject"
            },
            {
                "clash_mode": "Direct",
                "outbound": "direct"
            },
            {
                "clash_mode": "Global",
                "outbound": "proxy"
            },
            {
                "ip_is_private": true,
                "outbound": "direct"
            },
            {
                "rule_set": "geosite-geolocation-cn",
                "outbound": "direct"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geoip-cn"
                    },
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    }
                ],
                "outbound": "direct"
            },
            {
                "rule_set": "geosite-youtube",
                "outbound": "Youtube"
            },
            {
                "rule_set": "geosite-telegram",
                "outbound": "Telegram"
            },
            {
                "rule_set": ["geosite-twitter", "geosite-x"],
                "outbound": "Twitter/X"
            },
            {
                "rule_set": "geosite-x",
                "outbound": "X"
            },
            {
                "rule_set": "geosite-google",
                "outbound": "Google"
            },
            {
                "rule_set": "geosite-github",
                "outbound": "Github"
            },
            {
                "rule_set": "geosite-bahamut",
                "outbound": "Bahamut"
            },
            {
                "domain": ["hanime1.me"],
                "outbound": "proxy-no-jp"
            }            
        ],
        "final": "proxy",
        "default_domain_resolver": "dns_direct",
        "auto_detect_interface": true,
        "rule_set": [
            {
                "tag": "geosite-category-ads-all",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-youtube",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-youtube.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-telegram",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-telegram.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-twitter",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-twitter.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-x",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-x.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-google",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-google.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-github",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-github.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-bahamut",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-bahamut.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-geolocation-cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },
            {
                "tag": "geosite-geolocation-!cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            },            
            {
                "tag": "geoip-cn",
                "type": "remote",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
                "download_detour": "direct",
                "update_interval": "1d"
            }
        ]
    },
    "experimental": {
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": true,
            "store_rdrc": true,
            "rdrc_timeout": "7d"
        },
        "clash_api": {
            "external_controller": "127.0.0.1:9090",
            "external_ui": "ui",
            "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",
            "external_ui_download_detour": "direct",
            "secret": "",
            "default_mode": "Rule"
        }
    }
}
