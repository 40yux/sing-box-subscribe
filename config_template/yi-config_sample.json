{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "google",
         "address": "https://8.8.8.8/dns-query",
         "address_resolver": "dns_resolver",
         "strategy": "prefer_ipv4",
         "detour": "proxy"
      },
      {
        "tag": "local-dns",
        "address": "https://dns.alidns.com/dns-query",
        "address_resolver": "dns_resolver",
        "strategy": "prefer_ipv4",
        "detour": "direct"
      },
      {
        "tag": "dns_resolver",
        "address": "223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "fakeip-dns",
        "address": "fakeip"
      },
      {
        "tag": "block-dns",
        "address": "rcode://success"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "dns_resolver"
      },
      {
        "rule_set": [
          "geosite-geolocation-cn",
          "geosite-geolocation-!cn",
          "geosite-adblock"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip-dns"
      },
      {
        "domain_suffix": [
          "edu.cn",
          "gov.cn",
          "mil.cn",
          "ac.cn",
          "com.cn",
          "net.cn",
          "org.cn",
          "中国",
          "中國",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiq228c",
          "xn--fiq228c"
        ],
        "server": "local-dns"
      },
      {
        "rule_set": [
          "geosite-apple@cn",
          "geosite-icloud@cn"
        ],
        "server": "local-dns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "rewrite_ttl": 1,
        "server": "fakeip-dns"
      }
    ],
    "strategy": "ipv4_only",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "inet4_address": "172.16.0.1/30",
      "inet6_address": "fdfe:dcba:9876::1/126",
      "mtu": 1492,
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": false
     },
     {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "::",
      "listen_port": 5353,
      "users": [],            
      "sniff": true,
      "sniff_override_destination": false
     }
  ],
  "outbounds": [
    {
      "tag": "Proxy",
      "outbounds": [
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "tag": "Geolocation-cn",
      "outbounds": [
        "Proxy",
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "tag": "Geolocation-!cn",
      "outbounds": [
        "Proxy",
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "tag": "Cn",
      "outbounds": [
        "Proxy",
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "tag": "Adblock",
      "outbounds": [
        "Proxy",
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "tag": "Ad",
      "outbounds": [
        "Proxy",
        "➜ Direct"
      ],
      "interrupt_exist_connections": true,
      "type": "selector"
    },
    {
      "type": "direct",
      "tag": "➜ Direct"
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geosite-geolocation-cn",
        "url": "https://wiki.jokin.uk/geo/geosite/geolocation-cn.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geosite-geolocation-!cn",
        "url": "https://wiki.jokin.uk/geo/geosite/geolocation-!cn.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geoip-cn",
        "url": "https://wiki.jokin.uk/geo/geoip/cn.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geosite-adblock",
        "url": "https://wiki.jokin.uk/geo/geosite/adblock.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geoip-ad",
        "url": "https://wiki.jokin.uk/geo/geoip/ad.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geosite-apple@cn",
        "url": "https://wiki.jokin.uk/geo/geosite/apple@cn.srs"
      },
      {
        "type": "remote",
        "format": "binary",
        "download_detour": "direct",
        "tag": "geosite-icloud@cn",
        "url": "https://wiki.jokin.uk/geo/geosite/icloud@cn.srs"
      }
    ],
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "port": 53,
        "outbound": "dns-out"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 853
          },
          {
            "network": "udp",
            "port": 443
          },
          {
            "protocol": "stun"
          }
        ],
        "outbound": "block"
      },
      {
        "domain_suffix": [
          "edu.cn",
          "gov.cn",
          "mil.cn",
          "ac.cn",
          "com.cn",
          "net.cn",
          "org.cn",
          "中国",
          "中國",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiqz9s",
          "xn--fiqs8s",
          "xn--fiq228c",
          "xn--fiq228c"
        ],
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "Proxy"
      },
      {
        "rule_set": "geosite-geolocation-cn",
        "outbound": "Geolocation-cn"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "outbound": "Geolocation-!cn"
      },
      {
        "rule_set": "geoip-cn",
        "outbound": "Cn"
      },
      {
        "rule_set": "geosite-adblock",
        "outbound": "Adblock"
      },
      {
        "rule_set": "geoip-ad",
        "outbound": "Ad"
      },
      {
        "rule_set": [
          "geosite-apple@cn",
          "geosite-icloud@cn"
        ],
        "outbound": "direct"
      }
    ],
    "auto_detect_interface": true,
    "final": "Proxy"
  }
   "experimental": {
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": true
        },
        "clash_api": {
        "default_mode": "Enhanced",
        "external_controller": "127.0.0.1:9090",
        "external_ui": "./ui",
        "external_ui_download_detour": "direct"
        }
    }
}
