{
    "log": {
        "level": "info",
        "timestamp": true
    },
    "dns": {
        "servers": [
            {
                "tag": "proxy",
                "address": "https://8.8.8.8/dns-query",
                "address_resolver": "dns_resolver",
                "strategy": "prefer_ipv4",
                "detour": "proxy"
            },
            {
                "tag": "direct",
                "address": "https://dns.alidns.com/dns-query",
                "address_resolver": "dns_resolver",
                "strategy": "prefer_ipv4",
                "detour": "direct"
            },
            {
                "tag": "resolver",
                "address": "223.5.5.5",
                "detour": "direct"
            },
            {
                "tag": "block",
                "address": "rcode://success"
            },
            {
                "tag": "remote",
                "address": "fakeip"
            }
        ],
        "rules": [
            {
                "outbound": "any",
                "server": "resolver"
            },
            {
                "query_type": [
                  "A",
                  "AAAA"
                ],
                "server": "remote"
            },
            {
                "clash_mode": "Direct",
                "server": "direct"
            },
            {
                "clash_mode": "Global",
                "server": "proxy"
            },
            {
                "rule_set": "geosite-geolocation-cn",
                "server": "direct"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                  {
                    "rule_set": "geosite-geolocation-!cn"
                  },
                  {
                    "rule_set": "geoip-cn"
                  }
                ],
                "server": "proxy",
                "client_subnet": "114.114.114.114" // Any China client IP address
      }
        ],
        "final": "direct",
        "independent_cache": true,
        "fakeip": {
            "enabled": true,
            "inet4_range": "198.18.0.0/15",
            "inet6_range": "fc00::/18"
        }
    },
    "route": {
        "rule_set": [
            {
                "type": "remote",
                "tag": "geosite-geolocation-cn",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-cn.srs",
                "download_detour": "proxy"
            },
            {   "type": "remote",
                "tag": "geosite-geolocation-!cn",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-geolocation-!cn.srs",
                "download_detour": "proxy"
            },
            {
                "type": "remote",
                "tag": "geoip-cn",
                "format": "binary",
                "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
                "download_detour": "proxy"
            }
        ],
        "rules": [
            {
                "protocol": "dns",
                "outbound": "dns-out"
            },
            {
                "ip_is_private": true,
                "outbound": "direct"
            },
            {
                "clash_mode": "Direct",
                "outbound": "direct"
            },
            {
                "clash_mode": "Global",
                "outbound": "default"
            },
            {
                "port": 853,
                "network": "tcp",
                "outbound" "block"
            },
            {
                "port":[
                   443,
                   853
                ]
                "network": "udp",
                "outbound" "block"
            },
            {
               "rule_set": [
                 "geoip-cn",
                 "geosite-geolocation-cn"
               ],
               "outbound": "direct"
            }
        ],
        "final": "proxy",
        "auto_detect_interface": true
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "inet4_address": "172.16.0.1/30",
            "inet6_address": "fdfe:dcba:9876::1/126",
            "mtu": 1492,
            "auto_route": true,
            "strict_route": true,
            "stack": "system",
            "sniff": true,
            "sniff_override_destination": false
        },
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "::",
            "listen_port": 5353,
            "users": [],            
            "sniff": true,
            "sniff_override_destination": false
        }
    ],
    "outbounds": [
        {
            "tag":"proxy",
            "type":"selector",
            "outbounds":[
              "auto",
              "direct",
              "{all}"
            ]
        },
        {
            "tag":"Others",
            "type":"selector",
            "outbounds":[
              "{all}",
              "proxy"
          ],
            "filter":[
              {"action":"exclude","keywords":["ŵ­ŵḞ|HK|hk|éḊæẁŸ|éḊ|ŵṗŵỳ|TW|tw|åḞæṗẅ|åḞ|ŵẁŵỲ|SG|sg|æḞå åḂ|ç®|ŵŸŵṁ|JP|jp|æċæỲ|æċ|ŵẃŵẁ|US|us|çẅåẄ|çẅ|KR|kr|é©åẄ|UK|uk|èḟåẄ"]}
          ]
        },
        {
            "tag":"auto",
            "type":"urltest",
            "outbounds":[
              "{all}"
          ],
            "filter":[
              {"action":"exclude","keywords":["çẄçḋ|åḞå|å©äẄ|èṡæ|æ¶éṀ|ææ"]}
          ],
